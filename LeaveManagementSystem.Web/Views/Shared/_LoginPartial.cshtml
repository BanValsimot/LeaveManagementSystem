@using Microsoft.AspNetCore.Identity

<!-- Inject Identity services (provided by Dependency Injection) -->
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!-- Navigation container (used inside navbar in _Layout.cshtml) -->
<ul class="navbar-nav">

    @* Check if the user is signed in *@
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- ================= USER IS LOGGED IN ================= -->

        <li class="nav-item">
            <!-- Displays username and links to account management page -->
            <a class="nav-link text-light"
               asp-area="Identity"
               asp-page="/Account/Manage/Index"
               title="Manage">

                <!-- User.Identity.Name = current logged-in username -->
                Hello @User.Identity?.Name!
            </a>
        </li>

        <li class="nav-item">
            <!-- Logout form (POST request for security reasons) -->
            <form class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">

                <!-- Button styled like a link -->
                <button type="submit" class="nav-link btn btn-link text-light">
                    Logout
                </button>

            </form>
        </li>
    }
    else
    {
        <!-- ================= USER IS NOT LOGGED IN ================= -->

        <li class="nav-item">
            <!-- Link to Register page -->
            <a class="nav-link text-light"
               asp-area="Identity"
               asp-page="/Account/Register">
                Register
            </a>
        </li>

        <li class="nav-item">
            <!-- Link to Login page -->
            <a class="nav-link text-light"
               asp-area="Identity"
               asp-page="/Account/Login">
                Login
            </a>
        </li>
    }

</ul>